# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://corvin:STRONG_PASSWORD@corvin-db:5432/corvin
POSTGRES_USER=corvin
POSTGRES_PASSWORD=STRONG_PASSWORD
POSTGRES_DB=corvin

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:REDIS_PASSWORD@corvin-redis:6379/0
REDIS_PASSWORD=REDIS_PASSWORD

# ── Security — genera con: openssl rand -hex 32 ───────────────────────────────
SECRET_KEY=GENERATE_WITH_OPENSSL_RAND_HEX_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── MFA ───────────────────────────────────────────────────────────────────────
MFA_ISSUER=Corvin

# ── API Keys ──────────────────────────────────────────────────────────────────
HIBP_API_KEY=your-hibp-api-key
VIRUSTOTAL_API_KEY=your-virustotal-api-key
GOOGLE_SAFE_BROWSING_API_KEY=your-gsb-api-key
SENDGRID_API_KEY=your-sendgrid-api-key

# ── Email ─────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.com
SMTP_PASSWORD=your-smtp-password

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=production
LOG_LEVEL=INFO
ALLOWED_ORIGINS=["https://yourdomain.com"]
MAX_UPLOAD_SIZE_MB=10
UPLOAD_DIR=/app/uploads
